modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Redis"

[[workflows.workflow]]
name = "Redis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --port 6379 --save '' --appendonly no --dir /tmp"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
REDIS_URL = "redis://localhost:6379"
ELASTICSEARCH_URL = "http://localhost:9200"

[userenv.shared]
PLATFORM_ENCRYPTION_KEY = "e53eb1318543e51493e77cf78f872127303e61379b7cbe4d83c351e5ffb680e4"
ADMIN_INTERNAL_TOKEN = "thea_admin_d83fa038926385e909596c0827f1dd06d2e13c31"
