# ---------------------------------------------------------------------------
# THEA — self-hosting environment (docker compose).
# Copy this file next to docker-compose.yml:  cp .env.docker.example .env
# Then fill in the values below. NEVER commit your real .env.
#
# NOTE: PORT, DATABASE_URL, REDIS_URL and ELASTICSEARCH_URL are wired to the
# internal service names by docker-compose — do not set them here (except the
# optional DATABASE_URL override below for passwords with special characters).
# ---------------------------------------------------------------------------

# --- Local PostgreSQL (runs in the `db` container) -------------------------
POSTGRES_USER=thea
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=thea
# DATABASE_URL is built automatically from the three values above (host = the
# internal `db` service). Use a URL-safe password (letters, digits, - and _).
# If your password contains @ : / # ?, set a percent-encoded URL to override:
# DATABASE_URL=postgresql://thea:ENCODED_PASSWORD@db:5432/thea

# --- Reverse proxy ---------------------------------------------------------
# Hops in front of the API so rate limiting sees the real client IP.
#   standalone (compose only):            TRUST_PROXY=1
#   Cloudflare -> shared Caddy -> nginx:  TRUST_PROXY=3  (proxy mode)
TRUST_PROXY=3
LOG_LEVEL=info

# --- Standalone web ports (ignored in proxy mode) --------------------------
# Unique host ports per project on the VPS.
WEBSITE_PORT=8091
ADMIN_PORT=8092
MARKETS_PORT=8093

# --- Elasticsearch heap (raise if the host has spare RAM) ------------------
ES_JAVA_OPTS=-Xms512m -Xmx512m

# --- App URLs / CORS -------------------------------------------------------
API_ORIGIN=https://thea.quest
CORS_ORIGIN=https://thea.quest,https://admin.thea.quest,https://markets.thea.quest

# --- Encryption (REQUIRED for stored provider/LLM keys) --------------------
# Stable random secret (>=32 chars). Changing it invalidates stored encrypted
# keys. Generate once, e.g.:  openssl rand -hex 32
PLATFORM_ENCRYPTION_KEY=

# --- Internal admin/provisioning tokens ------------------------------------
ADMIN_INTERNAL_TOKEN=
PROVISION_TOKEN=

# --- LLM (required off-Replit; the Replit AI proxy is unavailable here) -----
OPENAI_API_KEY=

# --- Email delivery (Resend) — without these all email is a dry-run no-op ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=

# --- PayPal ----------------------------------------------------------------
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# --- Crypto payments -------------------------------------------------------
CRYPTO_CHAIN=polygon
CRYPTO_RECEIVING_ADDRESS=
CRYPTO_RPC_URL=
CRYPTO_USDT_ADDRESS=
CRYPTO_USDT_DECIMALS=6
CRYPTO_MIN_CONFIRMATIONS=12
CRYPTO_INTENT_TTL_MIN=30
POLYGON_RPC_URL=

# --- Ingestion (all optional) ----------------------------------------------
# Playwright crawling is OFF by default (keeps the api image lean). To enable,
# set true AND bake Chromium into the image (see the api stage in Dockerfile).
USE_PLAYWRIGHT=false
CRAWLEE_STORAGE_DIR=/tmp/crawlee
CRAWLER_PROXY_URLS=
RSSHUB_URL=
MIROFISH_URL=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
