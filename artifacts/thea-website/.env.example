# Public origin used for canonical URLs, Open Graph tags, and the generated sitemap.
# Set this to your production domain with no trailing slash (e.g. https://thea.quest).
# At runtime, canonical/OG tags fall back to the browser origin if this is unset,
# so the site still works without it — but the build-time sitemap.xml, the absolute
# og:image/og:url baked into index.html, and the robots.txt "Sitemap:" directive use
# this value (default below), so set it before deploying so search engines and social
# scrapers get correct absolute URLs. In Docker deploys this is wired via the
# WEBSITE_SITE_URL build arg in docker-compose.yml.
VITE_SITE_URL=https://thea.quest

# Absolute URL of the THEA Markets app (optional; defaults to "/markets/").
# VITE_MARKETS_URL=https://your-domain.com/markets/

# Absolute URL of the THEA Access PWA (optional; defaults to "/access-pwa/").
# In Docker deploys this is wired via the WEBSITE_ACCESS_URL build arg
# in docker-compose.yml (default https://m.thea.quest).
# VITE_ACCESS_URL=https://m.thea.quest
