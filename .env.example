# ============================================================
# THEA — Total Human Engagement Analytics
# Environment Variables Reference
# Copy this file to .env and fill in real values
# ============================================================

# ── Core ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=*

# ── Database (Phase 1) ───────────────────────────────────────
# PostgreSQL connection string (Replit provisions this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/thea

# ── Redis (Phase 1) ──────────────────────────────────────────
# Redis connection string for BullMQ job queue and caching
REDIS_URL=redis://localhost:6379

# ── Elasticsearch (Phase 1) ──────────────────────────────────
# Elasticsearch node URL for full-text search
# Can be left empty to disable ES features during development
ELASTICSEARCH_URL=http://localhost:9200

# ── OpenAI / LLM (Phase 3) ───────────────────────────────────
# Used for content classification, embeddings, report generation
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...
# Daily spend cap in USD (prevents runaway costs)
OPENAI_DAILY_SPEND_CAP_USD=50

# ── MiroFish (Phase 3) ───────────────────────────────────────
# URL of the running MiroFish service
MIROFISH_API_URL=http://localhost:8080
MIROFISH_API_KEY=

# ── Clerk Authentication (Phase 4) ───────────────────────────
CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Stripe Payments (Phase 4) ────────────────────────────────
STRIPE_SECRET_KEY=sk_...
STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ── Social Media APIs (Phase 2) ──────────────────────────────
# Twitter/X API v2
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Reddit OAuth2
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=THEA/1.0

# YouTube Data API v3
YOUTUBE_API_KEY=

# Telegram (GramJS / Telethon)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# TikTok Research API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── News APIs (Phase 2) ──────────────────────────────────────
NEWSAPI_KEY=
MEDIASTACK_KEY=
BING_NEWS_API_KEY=

# ── Web Search & Crawling (Phase 2) ──────────────────────────
# SerpAPI for live Google search results
SERPAPI_KEY=

# Proxy rotation for web crawling (Bright Data / Smartproxy / Oxylabs)
PROXY_ENDPOINT=
PROXY_USERNAME=
PROXY_PASSWORD=

# ── Notification Delivery (Phase 5) ──────────────────────────
# Resend for transactional email
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@thea.app

# Twilio for SMS alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Slack Bot for alert delivery
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# WhatsApp Business Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Storage (Phase 8) ────────────────────────────────────────
# Object storage for logos, PDF reports, exports
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# ── Integrations (Phase 8) ───────────────────────────────────
# Salesforce CRM
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# HubSpot CRM
HUBSPOT_ACCESS_TOKEN=

# ClaimBuster (disinformation detection)
CLAIMBUSTER_API_KEY=

# Mapbox (geographic heat maps)
MAPBOX_ACCESS_TOKEN=

# ── Internal ─────────────────────────────────────────────────
# HMAC secret for webhook payload signing
WEBHOOK_SIGNING_SECRET=

# Admin operator email (bypasses tier gating)
ADMIN_EMAIL=admin@thea.app
